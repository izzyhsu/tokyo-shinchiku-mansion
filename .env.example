# Public browser key for Google Maps JavaScript API only
# Restrict by exact web origins in Google Cloud Console
GOOGLE_MAPS_KEY_BROWSER=

# Private server key for Geocoding / Places APIs only
# Never expose this key to the browser
GOOGLE_MAPS_KEY_SERVER=

# Comma-separated frontend origins allowed to call /api/*
# Example: https://tokyo-shinchiku-mansion.onrender.com,https://izzyhsu.github.io
ALLOWED_ORIGINS=

# Optional explicit API base returned by /api/config
PUBLIC_API_BASE=

# Optional geocode API protection
GEOCODE_RATE_LIMIT_WINDOW_MS=60000
GEOCODE_RATE_LIMIT_MAX=30
